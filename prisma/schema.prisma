// Prisma schema — CollabImpact / Les Pilotes — Wave 0
//
// NOTE: Model names kept from v1 for minimal churn:
//   `User`      → aliased as "Participante" in the UI
//   `Immersion` → aliased as "Évent" in the UI
//
// Conventions
// - IDs cuid() (courts en URL)
// - `organisationId` sur toutes les entités métier (prêt multi-tenant)
// - Soft delete via `deletedAt`
// - Noms techniques en anglais, libellés UI en français

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================
// Enums
// =====================

enum EventType {
  FEMININ
  IMMERSION
  ATELIER
  IMPULSION
}

enum ImmersionStatus {
  brouillon
  publie
  complet
  en_cours
  termine
}

enum EnrollmentStatus {
  inscrit
  contactee
  confirmee_j7
  confirmee_j2
  presente
  absente
  desistement
  feedback_recu
}

enum EnrollmentMode {
  individuel
  via_referent
}

enum TaskPhase {
  PREPARATION
  WORKSHOP
  POST_EVENT
}

// =====================
// Entities
// =====================

model Organisation {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  admins      Admin[]
  immersions  Immersion[]
  enrollments Enrollment[]
}

// Administrateur du dashboard (identifié par email Supabase Auth).
// Whitelist : toute ligne présente ici peut se connecter via magic link.
model Admin {
  id             String       @id @default(cuid())
  organisationId String
  email          String       @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  @@index([organisationId])
}

// La participante — actrice principale de la plateforme (aliasée "User" pour compatibilité v1).
model User {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  supabaseAuthId String? @unique

  firstName        String
  lastName         String
  email            String  @unique
  phone            String?
  birthDate        DateTime? @db.Date
  city             String?
  source           String?  // "whatsapp" | "instagram" | "classe" | "conseiller" | "autre" | "bouche_a_oreille"
  reliabilityScore Int     @default(0)
  emailVerified    Boolean @default(false)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  enrollments Enrollment[]

  @@index([organisationId])
  @@index([email])
}

// Un évent (workshop, immersion…) — aliasé "Immersion" pour compatibilité v1.
model Immersion {
  id             String          @id @default(cuid())
  organisationId String
  organisation   Organisation    @relation(fields: [organisationId], references: [id])

  type        EventType       @default(FEMININ)
  name        String
  status      ImmersionStatus @default(brouillon)
  address     String
  date        DateTime
  capacity    Int
  description String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  enrollments Enrollment[]
  tasks       Task[]

  @@index([organisationId])
  @@index([date])
  @@index([status])
}

// Inscription d'une participante à un évent.
model Enrollment {
  id             String           @id @default(cuid())
  organisationId String
  organisation   Organisation     @relation(fields: [organisationId], references: [id])

  immersionId String
  immersion   Immersion @relation(fields: [immersionId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  status       EnrollmentStatus @default(inscrit)
  mode         EnrollmentMode   @default(individuel)
  referentName String?
  source       String?          // free string: whatsapp, instagram, etc.

  attendedAt DateTime? // émargement Jour J
  noShow     Boolean  @default(false)
  j7SentAt   DateTime?
  j2SentAt   DateTime?

  feedbackToken  String?   @unique
  feedbackSentAt DateTime?

  deletedAt  DateTime?
  enrolledAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  feedback Feedback?

  @@unique([immersionId, userId])
  @@index([organisationId])
  @@index([immersionId])
  @@index([userId])
  @@index([status])
}

// Réponse feedback post-évent.
model Feedback {
  id           String     @id @default(cuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  overallRating  Int     // 1-5
  orgRating      Int     // 1-5
  favoriteMoment String?
  changedVision  Boolean
  improvements   String?
  verbatim       String?

  submittedAt DateTime @default(now())

  @@index([submittedAt])
}

// Tâche de suivi liée à un évent.
model Task {
  id      String    @id @default(cuid())
  eventId String
  event   Immersion @relation(fields: [eventId], references: [id])

  phase       TaskPhase
  title       String
  description String?
  dueAt       DateTime?
  doneAt      DateTime?
  doneByEmail String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([eventId, phase])
}
