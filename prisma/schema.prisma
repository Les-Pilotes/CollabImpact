// Prisma schema — CollabImpact / Les Pilotes — Wave 0
//
// NOTE: Model names kept from v1 for minimal churn:
//   `User`      → aliased as "Participante" in the UI
//   `Immersion` → aliased as "Évent" in the UI
//
// Conventions
// - IDs cuid() (courts en URL)
// - `organisationId` sur toutes les entités métier (prêt multi-tenant)
// - Soft delete via `deletedAt`
// - Noms techniques en anglais, libellés UI en français

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================
// Enums
// =====================

enum EventType {
  FEMININ
  IMMERSION
  ATELIER
  IMPULSION
}

enum ImmersionStatus {
  brouillon
  publie
  complet
  en_cours
  termine
  archive
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum EnrollmentStatus {
  inscrit
  contactee
  confirmee_j7
  confirmee_j2
  presente
  absente
  desistement
  feedback_recu
}

enum EnrollmentMode {
  individuel
  via_referent
}

enum DroitsImageStatus {
  pending
  accepted
  refused
  minor_parental_pending
}

enum TaskPhase {
  PREPARATION
  WORKSHOP
  POST_EVENT
}

enum SpeakerStatus {
  invitee
  brief_envoye
  confirmee
}

// =====================
// Entities
// =====================

model Organisation {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  admins        Admin[]
  events        Event[]
  enrollments   Enrollment[]
  speakers      Speaker[]
  notifications Notification[]
  // V3: partnerCompanies PartnerCompany[]
}

// Administrateur du dashboard (identifié par email Supabase Auth).
// Whitelist : toute ligne présente ici peut se connecter via magic link.
model Admin {
  id             String       @id @default(cuid())
  organisationId String
  email          String       @unique
  firstName      String?
  lastName       String?
  role           AdminRole    @default(ADMIN)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  // Set the first time the admin signs in (and refreshed on subsequent
  // sessions). Used to differentiate "invitée, jamais connectée" from
  // "active" admins — see notification settings UI in event parametres.
  lastLoginAt    DateTime?
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  notificationReads NotificationRead[]

  @@index([organisationId])
}

// La participante — actrice principale de la plateforme (aliasée "User" pour compatibilité v1).
model User {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  supabaseAuthId String? @unique

  firstName        String
  lastName         String
  email            String    @unique
  phone            String?
  birthDate        DateTime? @db.Date
  gender           String? // "Fille" | "Garçon"
  city             String?
  source           String? // "whatsapp" | "instagram" | "classe" | "conseiller" | "autre" | "bouche_a_oreille"
  reliabilityScore Int       @default(0)
  emailVerified    Boolean   @default(false)

  // Couche Orientation — updated on inscription, refreshed if stale > 6 months
  niveauScolaire       String? // "3ème" | "2nde" | "1ère" | "Terminale" | "BTS" | "Licence" | "Master" | "Autres"
  niveauScolaireAutre  String?
  etablissement        String?
  region               String? // "Île-De-France" | "Hauts-de-France" | "Auvergne-Rhône-Alpes" | "Provence-Alpes-Côte d'Azur" | "Pays de la Loire"
  projetPro            String?
  motivation           String[]  @default([]) // multi-select serialized
  motivationDetail     String?
  commentConnu         String?
  orientationUpdatedAt DateTime?

  // Global droit-à-l'image consent (majeures only). Lifted from per-event so
  // we don't ask returning participants twice. NULL = never expressed an
  // opinion globally. Mineure consent stays on Enrollment because parental
  // consent doesn't carry over between events (RGPD).
  droitsImageStatus    DroitsImageStatus?
  droitsImageSignedAt  DateTime?
  droitsImageSignature String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  enrollments Enrollment[]

  @@index([organisationId])
  @@index([email])
  @@index([phone])
}

// Un évent (workshop, immersion…).
model Event {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  type        EventType       @default(FEMININ)
  name        String
  status      ImmersionStatus @default(brouillon)
  address     String
  date        DateTime
  endTime     DateTime?
  capacity    Int
  description String?

  // Per-event email customization
  replyToEmail   String?
  emailSignature String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Per-event admin notification settings (which alerts get sent, to whom).
  // JSON shape — see src/lib/notifications/config.ts:
  //   { newEnrollmentEnabled: boolean, recipientAdminIds: string[] }
  notificationConfig Json?

  enrollments    Enrollment[]
  tasks          Task[]
  speakers       Speaker[]
  groups         Group[]
  formConfig     FormConfig?
  feedbackConfig FeedbackConfig?
  emailConfig    EmailConfig?
  // V3 (requires migration): partnerCompany PartnerCompany?

  @@index([organisationId])
  @@index([date])
  @@index([status])
  @@map("Immersion")
}

// Inscription d'une participante à un évent.
model Enrollment {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  eventId String @map("immersionId")
  event   Event  @relation(fields: [eventId], references: [id])
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  status       EnrollmentStatus @default(inscrit)
  mode         EnrollmentMode   @default(individuel)
  referentName String?
  source       String? // free string: whatsapp, instagram, etc.

  attendedAt DateTime? // émargement Jour J
  noShow     Boolean   @default(false)
  j7SentAt   DateTime?
  j2SentAt   DateTime?

  feedbackToken  String?   @unique
  feedbackSentAt DateTime?

  // Couche Événement — answered at inscription, specific to this enrollment
  droitsImageStatus    DroitsImageStatus @default(pending)
  droitsImageSignedAt  DateTime?
  droitsImageSignature String? // digital signature: full name typed by the majeure
  regime               String[]          @default([]) // multi-select: ["Végétarien", "Sans gluten", ...]
  accessibilite        String?
  accompagnateur       Boolean           @default(false)
  commentaire          String?

  // Admin-only internal note (not visible to participante)
  internalNote String?

  deletedAt  DateTime?
  enrolledAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  feedback Feedback?
  // V3: groupId String?, group Group?

  @@unique([eventId, userId])
  @@index([organisationId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
}

// Réponse feedback post-évent.
model Feedback {
  id           String     @id @default(cuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  overallRating  Int // 1-5
  orgRating      Int // 1-5
  favoriteMoment String?
  changedVision  Boolean
  improvements   String?
  verbatim       String?

  submittedAt DateTime @default(now())

  @@index([submittedAt])
}

// Tâche de suivi liée à un évent.
model Task {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  phase       TaskPhase
  title       String
  description String?
  dueAt       DateTime?
  doneAt      DateTime?
  doneByEmail String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([eventId, phase])
}

/// Intervenante — professionnelle invitée à un workshop
model Speaker {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  firstName String
  lastName  String
  jobTitle  String?
  company   String?
  domain    String? // ex: "Informatique", "Marketing"
  bio       String?
  photoUrl  String?

  status SpeakerStatus @default(invitee)

  profileToken  String @unique @default(cuid())
  feedbackToken String @unique @default(cuid())

  profileSubmittedAt  DateTime?
  feedbackSubmittedAt DateTime?

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  group Group?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([organisationId])
  @@index([eventId])
  @@index([status])
}

/// Groupe workshop — une intervenante + N participantes
model Group {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  speakerId String?  @unique
  speaker   Speaker? @relation(fields: [speakerId], references: [id])

  name  String
  order Int    @default(0)

  // V3 (requires groupId on Enrollment + migration): enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
}

/// Configuration du formulaire d'inscription d'un event
model FormConfig {
  id      String @id @default(cuid())
  eventId String @unique
  event   Event  @relation(fields: [eventId], references: [id])

  phoneEnabled     Boolean @default(true)
  birthDateEnabled Boolean @default(true)
  cityEnabled      Boolean @default(true)
  sourceEnabled    Boolean @default(true)

  // Couche Orientation
  niveauScolaireEnabled Boolean @default(true)
  regionEnabled         Boolean @default(true)
  projetProEnabled      Boolean @default(true)
  motivationEnabled     Boolean @default(true)

  // Couche Événement
  droitsImageEnabled   Boolean @default(true)
  regimeEnabled        Boolean @default(true)
  accessibiliteEnabled Boolean @default(true)
  commentaireEnabled   Boolean @default(true)

  // Format: [{ "id": "cuid", "label": "...", "type": "text|select", "required": bool, "options": [...] }]
  customFields Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Configuration du formulaire de feedback post-event
model FeedbackConfig {
  id      String @id @default(cuid())
  eventId String @unique
  event   Event  @relation(fields: [eventId], references: [id])

  satisfactionEnabled    Boolean @default(true)
  highlightsEnabled      Boolean @default(true)
  favoriteSpeakerEnabled Boolean @default(true)
  recommendEnabled       Boolean @default(true)

  customFields Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Per-event email customisation — optional overrides for each transactional email
model EmailConfig {
  id      String @id @default(cuid())
  eventId String @unique
  event   Event  @relation(fields: [eventId], references: [id])

  // Inscription confirmation
  confirmationSubject String?
  confirmationBody    String?
  confirmationNote    String?

  // J-7 reminder
  j7Subject String?
  j7Body    String?
  j7Note    String?

  // J-2 reminder
  j2Subject String?
  j2Body    String?
  j2Note    String?

  // Feedback invite
  feedbackSubject String?
  feedbackBody    String?
  feedbackNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// In-app notification for admin dashboard. One row per org event (deduplicated
/// across admins); per-admin read state is tracked in NotificationRead.
model Notification {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  /// "enrollment.created" | "event.capacity_reached" | "event.status_changed" | "feedback.received"
  type         String
  title        String
  body         String?
  eventId      String?
  enrollmentId String?
  metadata     Json?

  createdAt DateTime @default(now())

  reads NotificationRead[]

  @@index([organisationId, createdAt])
  @@index([eventId, type])
}

/// Per-admin read state for a notification.
model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  adminId        String
  readAt         DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  admin        Admin        @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([notificationId, adminId])
  @@index([adminId])
}

// V3: model PartnerCompany (requires partnerCompanyId FK on Event + migration)
